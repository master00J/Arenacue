NEXT_PUBLIC_SITE_URL=https://arenacue.be

# Standaard download op /licentie (actieve licenties). Bestand: Website/public/downloads/Stadium-Scoreboard.exe
# (wordt gevuld via prebuild: lokale ../dist of PORTABLE_EXE_FETCH_URL op Vercel — .exe past niet in GitHub <100 MB).
NEXT_PUBLIC_PORTAL_DOWNLOAD_URL=/downloads/Stadium-Scoreboard.exe
# Optioneel: knoptekst op het portaal (default: "ArenaCue voor Windows").
NEXT_PUBLIC_PORTAL_DOWNLOAD_LABEL=

# Alleen bij Vercel-build: directe HTTPS-URL naar Stadium-Scoreboard.exe (Supabase Storage, S3, …) zodat prebuild het kan ophalen.
# PORTABLE_EXE_FETCH_URL=

# Nodig voor demo-aanvragen via Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Alleen server-side (Vercel): voor licentie-API (/api/license/*). Nooit in de browser zetten.
SUPABASE_SERVICE_ROLE_KEY=

# Admin UI: publiek URL-segment (geen slashes). Standaard "admin". Zet op Vercel iets willekeurigs, bv. j9k-m4nt-7xq
# → site op /j9k-m4nt-7xq/... ; /admin geeft 404. Alleen [A-Za-z0-9_-], 2–80 tekens.
NEXT_PUBLIC_ADMIN_PATH=admin

# Admin-login: sterk wachtwoord + JWT-geheim (min. 24 tekens).
ADMIN_LICENSE_PASSWORD=
ADMIN_SESSION_SECRET=

# E-mail na demo-aanvraag (https://resend.com — domein arenacue.be verifiëren, API key aanmaken).
RESEND_API_KEY=
# Afzender (moet een adres op je geverifieerde domein bij Resend zijn).
RESEND_FROM="ArenaCue <info@arenacue.be>"
# Interne notificatie + reply-to voor de bevestigingsmail naar de aanvrager.
DEMO_NOTIFY_EMAIL=info@arenacue.be
