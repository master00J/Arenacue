# Openbare site-origin staat vast op https://arenacue.be (zie lib/site-url.ts: CANONICAL_SITE_ORIGIN).
# NEXT_PUBLIC_SITE_URL is niet meer nodig voor maillinks/sitemap; oude Vercel-var mag je verwijderen.

# Optioneel: Google Search Console site-verificatie (meta tag content-waarde).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Standaard download op /portal (actieve licenties). Bestand: public/downloads/Stadium-Scoreboard.exe
# (prebuild: eerst ../dist-latest/Stadium-Scoreboard.exe, anders ../dist/, of PORTABLE_EXE_FETCH_URL op Vercel — .exe past niet in GitHub <100 MB).
NEXT_PUBLIC_PORTAL_DOWNLOAD_URL=/downloads/Stadium-Scoreboard.exe
# Optioneel: knoptekst op het portaal (default: "ArenaCue voor Windows").
NEXT_PUBLIC_PORTAL_DOWNLOAD_LABEL=

# Alleen bij Vercel-build: directe HTTPS-URL naar Stadium-Scoreboard.exe (Supabase Storage, S3, …) zodat prebuild het kan ophalen.
# PORTABLE_EXE_FETCH_URL=

# Runtime (Vercel): als /downloads/Stadium-Scoreboard.exe niet in de deploy zit, 307-redirect naar deze HTTPS-URL.
# Zet dit bv. naar een publieke Supabase Storage-URL. Niet combineren met een geslaagde prebuild-kopie (dan overschrijft redirect het lokale bestand).
# DOWNLOAD_STADIUM_EXE_REDIRECT_URL=

# Desktopapp versiecheck (GET /api/app/release). Optioneel overschrijven; default = data/app-release.json in de repo.
# APP_RELEASE_VERSION=
# APP_RELEASE_DOWNLOAD_URL=
# APP_RELEASE_TITLE=
# APP_RELEASE_NOTES=

# Nodig voor demo-aanvragen via Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Alleen server-side (Vercel): voor licentie-API (/api/license/*). Nooit in de browser zetten.
SUPABASE_SERVICE_ROLE_KEY=

# Admin UI: publiek URL-segment (geen slashes). Standaard "admin". Zet op Vercel iets willekeurigs, bv. j9k-m4nt-7xq
# → site op /j9k-m4nt-7xq/... ; /admin geeft 404. Alleen [A-Za-z0-9_-], 2–80 tekens.
NEXT_PUBLIC_ADMIN_PATH=admin

# Admin-login: sterk wachtwoord + JWT-geheim (min. 24 tekens).
ADMIN_LICENSE_PASSWORD=
ADMIN_SESSION_SECRET=

# Klantportaal (/portal): magic-link login gebruikt hetzelfde type JWT als admin.
# Optioneel apart geheim; zo niet gezet wordt ADMIN_SESSION_SECRET gebruikt.
# PORTAL_SESSION_SECRET=

# Demo-licenties automatisch na demo-aanvraag (trial in Supabase). Uit: DEMO_LICENSE_AUTO_PROVISION=false
# DEMO_LICENSE_VALID_DAYS=14
# DEMO_LICENSE_MAX_ACTIVATIONS=2
# E-mail na demo-aanvraag (https://resend.com — domein arenacue.be verifiëren, API key aanmaken).
RESEND_API_KEY=
# Afzender (moet een adres op je geverifieerde domein bij Resend zijn).
RESEND_FROM="ArenaCue <info@arenacue.be>"
# Interne notificatie + reply-to voor de bevestigingsmail naar de aanvrager.
DEMO_NOTIFY_EMAIL=info@arenacue.be
