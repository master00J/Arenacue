NEXT_PUBLIC_SITE_URL=https://arenacue.be

# Standaard download op /licentie (actieve licenties). Scoreboard: Website/public/downloads/Stadium-Scoreboard.exe
# (prebuild: eerst ../dist-latest/Stadium-Scoreboard.exe, anders ../dist/, of PORTABLE_EXE_FETCH_URL op Vercel — .exe past niet in GitHub <100 MB).
NEXT_PUBLIC_PORTAL_DOWNLOAD_URL=/downloads/Stadium-Scoreboard.exe
# Optioneel: tweede knop voor LED boarding (zelfde patroon als scoreboard).
NEXT_PUBLIC_PORTAL_LEDBOARDING_DOWNLOAD_URL=/downloads/ArenaCue-Ledboarding.exe
# Optioneel: knopteksten op het portaal.
NEXT_PUBLIC_PORTAL_DOWNLOAD_LABEL=
NEXT_PUBLIC_PORTAL_LEDBOARDING_DOWNLOAD_LABEL=

# Alleen bij Vercel-build: directe HTTPS-URL naar portable .exe zodat prebuild ze kan ophalen.
# PORTABLE_EXE_FETCH_URL=
# PORTABLE_LEDBOARDING_FETCH_URL=

# Runtime (Vercel): als het bestand niet in de deploy zit, 307-redirect naar deze HTTPS-URL(s).
# DOWNLOAD_STADIUM_EXE_REDIRECT_URL=
# DOWNLOAD_LEDBOARDING_EXE_REDIRECT_URL=

# Desktopapp versiecheck (GET /api/app/release). Optioneel overschrijven; default = data/app-release.json in de repo.
# APP_RELEASE_VERSION=
# APP_RELEASE_DOWNLOAD_URL=
# APP_RELEASE_TITLE=
# APP_RELEASE_NOTES=

# Nodig voor demo-aanvragen via Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Alleen server-side (Vercel): voor licentie-API (/api/license/*), demo-licentie-aanmaak, klantportaal-backend.
# Vereist voor automatische demo-sleutel na demo-formulier. Nooit in de browser zetten.
SUPABASE_SERVICE_ROLE_KEY=

# Demo: automatisch trial-licentie aanmaken na succesvolle demo-aanvraag (default aan als SERVICE_ROLE gezet is).
# DEMO_LICENSE_AUTO_PROVISION=false
# DEMO_LICENSE_VALID_DAYS=14
# DEMO_LICENSE_MAX_ACTIVATIONS=2

# Admin UI: publiek URL-segment (geen slashes). Standaard "admin". Zet op Vercel iets willekeurigs, bv. j9k-m4nt-7xq
# → site op /j9k-m4nt-7xq/... ; /admin geeft 404. Alleen [A-Za-z0-9_-], 2–80 tekens.
NEXT_PUBLIC_ADMIN_PATH=admin

# Admin-login: sterk wachtwoord + JWT-geheim (min. 24 tekens).
ADMIN_LICENSE_PASSWORD=
ADMIN_SESSION_SECRET=

# Cloud control relay (Optie A): mobiele app via internet -> Website API -> desktop agent.
# Min. 24 tekens voor CONTROL_SESSION_SECRET.
CONTROL_SESSION_SECRET=
# PIN voor operator-sessies in mobile cloud auth.
CONTROL_OPERATOR_PIN=
# Shared secret header tussen desktop-agent en Website API.
CONTROL_DESKTOP_KEY=

# E-mail na demo-aanvraag (https://resend.com — domein arenacue.be verifiëren, API key aanmaken).
RESEND_API_KEY=
# Afzender (moet een adres op je geverifieerde domein bij Resend zijn).
RESEND_FROM="ArenaCue <info@arenacue.be>"
# Interne notificatie + reply-to voor de bevestigingsmail naar de aanvrager.
DEMO_NOTIFY_EMAIL=info@arenacue.be
